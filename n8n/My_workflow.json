    {
      "parameters": {
        "jsCode": "const raw = ($input.first().json.choices?.[0]?.message?.content ?? \"\").replace(/\\r\\n/g, \"\\n\");\n\nconst re = /(^\\d+\\n\\d{2}:\\d{2}:\\d{2},\\d{3}\\s*-->\\s*\\d{2}:\\d{2}:\\d{2},\\d{3}\\n(?:.*(?:\\n|$))+?)(?=\\n{2,}\\d+\\n|\\n*$)/gm;\n\nconst blocks = [];\nlet m;\nwhile ((m = re.exec(raw)) !== null) {\n  const block = m[1].split(\"\\n\").map(l => l.trimEnd()).join(\"\\n\").trim();\n  blocks.push(block);\n}\n\nif (!blocks.length) {\n  throw new Error(\"Не найдено ни одного SRT-блока в ответе модели\");\n}\n\nconst srt_ru = blocks.join(\"\\n\\n\") + \"\\n\";\n\nreturn [{ json: { srt_ru } }];\n"
      },
