    {
      "parameters": {
        "jsCode": "const srt = $input.first().json.srtText;\n\nreturn [{\n  json: {\n    model: \"Qwen/Qwen2.5-0.5B-Instruct-AWQ\",\n    temperature: 0,\n    messages: [\n      {\n        role: \"user\",\n        content:\n          \"Переведи субтитры EN --> RU. Сохраняй переносы строк внутри блока. Не меняй таймкоды и номера.\\n\\n\" +\n          srt\n      }\n    ]\n  }\n}];\n"
      },
      "id": "a9e6a712-c588-4dea-8ec8-6f2370660858",
      "name": "Code5",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
