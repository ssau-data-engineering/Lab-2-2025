    },
    {
      "parameters": {
        "jsCode": "let raw = ($input.first().json.choices?.[0]?.message?.content ?? \"\").replace(/\\r\\n/g, \"\\n\");\n\n// 0) обрезаем всё до первого таймкода (убирает \"Конечно...\", пояснения и т.п.)\nconst tci = raw.search(/\\d{2}:\\d{2}:\\d{2},\\d{3}\\s*-->\\s*\\d{2}:\\d{2}:\\d{2},\\d{3}/);\nif (tci === -1) throw new Error(\"В ответе нет таймкодов SRT\");\nraw = raw.slice(Math.max(0, tci - 50)); // небольшой запас на номер\n\n// 1) чинит \"1. 00:00:...\" или \"1) 00:00...\" или \"1 00:00...\" -> \"1\\n00:00...\"\nraw = raw.replace(\n  /(^|\\n)\\s*(\\d+)\\s*[.)]?\\s*(\\d{2}:\\d{2}:\\d{2},\\d{3}\\s*-->\\s*\\d{2}:\\d{2}:\\d{2},\\d{3})/g,\n  \"$1$2\\n$3\"\n);\n\n// 2) гарантируем перенос строки после таймкода (если модель лепит текст в ту же строку)\nraw = raw.replace(\n  /(\\d{2}:\\d{2}:\\d{2},\\d{3}\\s*-->\\s*\\d{2}:\\d{2}:\\d{2},\\d{3})[ \\t]+/g,\n  \"$1\\n\"\n);\n\n// 3) нормализуем пустые строки (между блоками оставим 1 пустую)\nraw = raw.replace(/\\n{3,}/g, \"\\n\\n\").trim() + \"\\n\";\n\n// 4) теперь можно парсить блоки\nconst re =\n  /(^\\d+\\n\\d{2}:\\d{2}:\\d{2},\\d{3}\\s*-->\\s*\\d{2}:\\d{2}:\\d{2},\\d{3}\\n(?:.*(?:\\n|$))+?)(?=\\n{2,}\\d+\\n|\\n*$)/gm;\n\nconst blocks = [];\nlet m;\nwhile ((m = re.exec(raw)) !== null) {\n  const block = m[1].split(\"\\n\").map(l => l.trimEnd()).join(\"\\n\").trim();\n  blocks.push(block);\n}\n\nif (!blocks.length) {\n  // очень полезно видеть, что реально пришло после нормализации\n  throw new Error(\"Не найдено ни одного SRT-блока после нормализации. Tail:\\n\" + raw.slice(0, 800));\n}\n\nconst srt_ru = blocks.join(\"\\n\\n\") + \"\\n\";\nreturn [{ json: { srt_ru } }];\n"
      },
