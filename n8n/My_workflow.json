    {
      "parameters": {
        "jsCode": "const srt = $input.first().json;\nconst srtText = typeof srt === 'string' ? srt : (srt.data || srt.body || srt.text || '');\n\nif (!srtText || !srtText.includes('-->')) {\n  throw new Error('SRT не похож на SRT. Проверь Response Format в STT HTTP Request.');\n}\n\nconst blocks = srtText.trim().split(/\\n\\s*\\n/);\nconst segments = [];\n\nfor (const b of blocks) {\n  const lines = b.split('\\n').map(l => l.trim()).filter(Boolean);\n  if (lines.length < 3) continue;\n\n  const idx = lines[0];\n  const time = lines[1];\n  const text = lines.slice(2).join('\\n');\n\n  segments.push({ idx, time, text });\n}\n\nreturn [{ json: { segments, srtText } }];\n"
