      "parameters": {
        "jsCode": "const msg = $input.first().json.message;\n\nlet fileId = null;\nlet fileName = null;\n\nif (msg?.video?.file_id) {\n  fileId = msg.video.file_id;\n  fileName = msg.video.file_name || 'video.mp4';\n} else if (msg?.document?.file_id) {\n  fileId = msg.document.file_id;\n  fileName = msg.document.file_name || 'file.bin';\n} else {\n  // чтобы понять что пришло — покажем ключи\n  throw new Error('Нет video/document. Доступные поля message: ' + Object.keys(msg || {}).join(', '));\n}\n\nreturn [{ json: { fileId, fileName, chatId: msg.chat.id } }];\n"
      },
